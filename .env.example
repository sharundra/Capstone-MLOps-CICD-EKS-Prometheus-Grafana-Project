# Copy this file to .env and update the values with your own credentials
# NOTE: .env is in .gitignore and will NOT be committed to git

# MLflow & DAGsHub Configuration
# Replace these with your DAGsHub credentials
MLFLOW_TRACKING_URI=https://dagshub.com/YOUR_USERNAME/YOUR_REPO.mlflow
DAGSHUB_REPO_OWNER=YOUR_USERNAME
DAGSHUB_REPO_NAME=YOUR_REPO_NAME

# Experiment Configuration
EXPERIMENT_NAME1=Your Experiment Name
EXPERIMENT_NAME2=Your Other Experiment Name

# Data Configuration
DATA_PATH=notebooks/data.csv
TEST_SIZE=0.2

